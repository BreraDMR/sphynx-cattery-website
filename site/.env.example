# Copy this file to .env and adjust if your local setup differs.
# These defaults match a typical local MAMP/XAMPP MySQL install -- not
# secrets, just convenience values for running this demo locally.

DB_HOST=localhost
DB_NAME=sphynx_prague
DB_USER=root
DB_PASSWORD=root

# Demo admin login for /login.php -- change both (and regenerate the hash)
# before using this anywhere beyond a local demo:
#   php -r "echo password_hash('your-new-password', PASSWORD_BCRYPT), PHP_EOL;"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$/aHMxiyAvkalENkqc2.5xOQJTdj6ua/Mb2qJ8TIbp6RUb9yJzqQhi

# Shared secret for api/cats.php and api/requests.php's machine-to-machine
# endpoints -- the sphynx-cats-crm-bot Telegram bot sends this back as an
# `X-API-Key` header. Generate a real one with:
#   openssl rand -hex 24
BOT_API_KEY=

# Where sphynx-cats-crm-bot's notify endpoint lives -- api.php POSTs new
# contact-form submissions here so admins see them in Telegram, not just
# in admin_requests.php. Optional: leave empty to skip notifications
# entirely (BotNotifier no-ops if this is unset).
NOTIFY_URL=
